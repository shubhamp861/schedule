{
  "Monday": {
    "day": {
      "time": "Morning (7:00 - 8:00 AM)",
      "steps": [
        {
          "product": "Salicylic Acid Face Wash",
          "instruction": "Massage for 20-30 seconds on wet face and rinse with lukewarm water"
        },
        {
          "product": "Derma Decode 10% Azelaic Acid Serum",
          "instruction": "Apply pea-sized amount on dry face and wait 60 seconds"
        },
        {
          "product": "Minimalist 10% Niacinamide Serum",
          "instruction": "Apply 2-3 drops and gently pat into skin. Wait 60 seconds"
        },
        {
          "product": "Oil-Free Gel Moisturizer",
          "instruction": "Apply pea-sized amount evenly on face"
        },
        {
          "product": "Sunscreen SPF 30+",
          "instruction": "Apply 2 finger-length amount evenly on face and neck"
        }
      ]
    },
    "night": {
